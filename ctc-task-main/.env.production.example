# Backend runtime
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: SQLite (default, no extra setup)
DB_PATH=/root/.openclaw/workspace/ctc-task/ctc-task-main/backend/database.sqlite
DB_PROVIDER=sqlite

# Option B: PostgreSQL (set DATABASE_URL to switch; DB_PROVIDER must match)
# DATABASE_URL=postgresql://user:password@localhost:5432/ctctask
# DB_PROVIDER=postgresql

# Security keys (MUST change in production)
JWT_SECRET=change-me-to-a-random-32-char-string
MAIL_ENCRYPTION_KEY=change-me-to-exactly-32-bytes!!

# SMTP mail configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="CTC Task <no-reply@example.com>"

# Frontend build-time variables
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
